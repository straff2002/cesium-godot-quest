
[configuration]

entry_symbol = "test_cesium_init"

compatibility_minimum = 4.2

[libraries]
windows.debug.x86_64 = "res://addons/cesium_godot/lib/Godot3DTiles.windows.template_release.x86_64.dll"
windows.release.x86_64 = "res://addons/cesium_godot/lib/Godot3DTiles.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://addons/cesium_godot/lib/libGodot3DTiles.linux.template_release.x86_64.so"
linux.release.x86_64 = "res://addons/cesium_godot/lib/libGodot3DTiles.linux.template_release.x86_64.so"
android.debug.arm64 = "res://addons/cesium_godot/lib/libGodot3DTiles.android.template_release.arm64.so"
android.release.arm64 = "res://addons/cesium_godot/lib/libGodot3DTiles.android.template_release.arm64.so"


[icons]
CesiumGeoreference = "res://addons/cesium_godot/resources/icons/globe.svg"
Cesium3DTileset = "res://addons/cesium_godot/resources/icons/box.svg"
CesiumIonRasterOverlay = "res://addons/cesium_godot/resources/icons/image.svg"
CesiumDynamicCam = "res://addons/cesium_godot/resources/icons/video.svg"
CesiumOrbitCam = "res://addons/cesium_godot/resources/icons/orbit.svg"
